{"id": "test-00867", "text": "BOMBAY, India 1996-12-06", "gold_mentions": [{"start": 0, "end": 6, "ent_type": "LOC", "text": "BOMBAY"}, {"start": 8, "end": 13, "ent_type": "LOC", "text": "India"}]}
{"id": "test-00868", "text": "World number two Rodney Eyles moved within sight of his fifth title of the year on Friday when he hurried in only 40 minutes to the final of the richest squash tournament outside the World Open, the $105,000 Mahindra International.", "gold_mentions": [{"start": 17, "end": 29, "ent_type": "PER", "text": "Rodney Eyles"}, {"start": 183, "end": 193, "ent_type": "MISC", "text": "World Open"}, {"start": 208, "end": 230, "ent_type": "MISC", "text": "Mahindra International"}]}
{"id": "test-00869", "text": "The Australian brushed aside unseeded Englishman Mark Cairns 15-7 15-6 15-8.", "gold_mentions": [{"start": 4, "end": 14, "ent_type": "MISC", "text": "Australian"}, {"start": 38, "end": 48, "ent_type": "MISC", "text": "Englishman"}, {"start": 49, "end": 60, "ent_type": "PER", "text": "Mark Cairns"}]}
{"id": "test-00870", "text": "Top-seeded Eyles now meets titleholder Peter Nicol of Scotland who overcame Simon Parke of England 15-7 15-12 15-12.", "gold_mentions": [{"start": 11, "end": 16, "ent_type": "PER", "text": "Eyles"}, {"start": 39, "end": 50, "ent_type": "PER", "text": "Peter Nicol"}, {"start": 54, "end": 62, "ent_type": "LOC", "text": "Scotland"}, {"start": 76, "end": 87, "ent_type": "PER", "text": "Simon Parke"}, {"start": 91, "end": 98, "ent_type": "LOC", "text": "England"}]}
