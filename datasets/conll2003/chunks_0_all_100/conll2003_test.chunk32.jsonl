{"id": "test-03169", "text": "Defenders - Rudi Vata, Saimir Malko, Arjan Xhumba, Ilir Shulku, Afrim Tole, Nevil Dede, Arjan Bellai", "gold_mentions": [{"start": 12, "end": 21, "ent_type": "PER", "text": "Rudi Vata"}, {"start": 23, "end": 35, "ent_type": "PER", "text": "Saimir Malko"}, {"start": 37, "end": 49, "ent_type": "PER", "text": "Arjan Xhumba"}, {"start": 51, "end": 62, "ent_type": "PER", "text": "Ilir Shulku"}, {"start": 64, "end": 74, "ent_type": "PER", "text": "Afrim Tole"}, {"start": 76, "end": 86, "ent_type": "PER", "text": "Nevil Dede"}, {"start": 88, "end": 100, "ent_type": "PER", "text": "Arjan Bellai"}]}
