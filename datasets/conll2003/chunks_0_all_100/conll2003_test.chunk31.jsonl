{"id": "test-03043", "text": "SOCCER - VIEIRA SAVES ARSENAL WITH LAST-MINUTE EQUALISER.", "gold_mentions": [{"start": 9, "end": 15, "ent_type": "PER", "text": "VIEIRA"}, {"start": 22, "end": 29, "ent_type": "ORG", "text": "ARSENAL"}]}
{"id": "test-03044", "text": "LONDON 1996-12-07", "gold_mentions": [{"start": 0, "end": 6, "ent_type": "LOC", "text": "LONDON"}]}
{"id": "test-03045", "text": "Frenchman Patrick Vieira blasted a last-minute goal to salvage a 2-2 draw for English premier league leaders Arsenal at home to Derby on Saturday.", "gold_mentions": [{"start": 0, "end": 9, "ent_type": "MISC", "text": "Frenchman"}, {"start": 10, "end": 24, "ent_type": "PER", "text": "Patrick Vieira"}, {"start": 78, "end": 85, "ent_type": "MISC", "text": "English"}, {"start": 109, "end": 116, "ent_type": "ORG", "text": "Arsenal"}, {"start": 128, "end": 133, "ent_type": "ORG", "text": "Derby"}]}
{"id": "test-03046", "text": "The London club had been rocked by a two-goal burst from forwards Dean Sturridge and Darryl Powell in the 62nd and 71st minutes which overturned Arsenal's 1-0 lead from a diving header by captain Tony Adams on the stroke of halftime.", "gold_mentions": [{"start": 4, "end": 10, "ent_type": "LOC", "text": "London"}, {"start": 66, "end": 80, "ent_type": "PER", "text": "Dean Sturridge"}, {"start": 85, "end": 98, "ent_type": "PER", "text": "Darryl Powell"}, {"start": 145, "end": 152, "ent_type": "ORG", "text": "Arsenal"}, {"start": 196, "end": 206, "ent_type": "PER", "text": "Tony Adams"}]}
{"id": "test-03047", "text": "Liverpool suffered an upset first home league defeat of the season, beaten 1-0 by a Guy Whittingham goal for Sheffield Wednesday.", "gold_mentions": [{"start": 0, "end": 9, "ent_type": "ORG", "text": "Liverpool"}, {"start": 84, "end": 99, "ent_type": "PER", "text": "Guy Whittingham"}, {"start": 109, "end": 128, "ent_type": "ORG", "text": "Sheffield Wednesday"}]}
{"id": "test-03048", "text": "Wimbledon leap-frogged over Liverpool into second place by winning 3-1 at Sunderland to extend their unbeaten league and cup run to 18 games.", "gold_mentions": [{"start": 0, "end": 9, "ent_type": "ORG", "text": "Wimbledon"}, {"start": 28, "end": 37, "ent_type": "ORG", "text": "Liverpool"}, {"start": 74, "end": 84, "ent_type": "ORG", "text": "Sunderland"}]}
{"id": "test-03049", "text": "Two strikes by Efan Ekoku in the first half and a late goal from fellow forward Dean Holdsworth secured victory for Wimbledon, who trail pacemakers Arsenal by four points.", "gold_mentions": [{"start": 15, "end": 25, "ent_type": "PER", "text": "Efan Ekoku"}, {"start": 80, "end": 95, "ent_type": "PER", "text": "Dean Holdsworth"}, {"start": 116, "end": 125, "ent_type": "ORG", "text": "Wimbledon"}, {"start": 148, "end": 155, "ent_type": "ORG", "text": "Arsenal"}]}
{"id": "test-03050", "text": "SOCCER - SCOTTISH LEAGUE AND CUP RESULTS.", "gold_mentions": [{"start": 9, "end": 17, "ent_type": "MISC", "text": "SCOTTISH"}]}
