{"id": "test-02590", "text": "VAIL, Colorado 1996-12-07", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "LOC", "text": "VAIL"}, {"start": 6, "end": 14, "ent_type": "LOC", "text": "Colorado"}]}
{"id": "test-02591", "text": "Renate Goetschl of Austria won the women's World Cup downhill race on Saturday, according to provisional results.", "gold_mentions": [{"start": 0, "end": 15, "ent_type": "PER", "text": "Renate Goetschl"}, {"start": 19, "end": 26, "ent_type": "LOC", "text": "Austria"}, {"start": 43, "end": 52, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-02592", "text": "Katja Seizinger of Germany finished second and Islode Kostner of Italy took third.", "gold_mentions": [{"start": 0, "end": 15, "ent_type": "PER", "text": "Katja Seizinger"}, {"start": 19, "end": 26, "ent_type": "LOC", "text": "Germany"}, {"start": 47, "end": 61, "ent_type": "PER", "text": "Islode Kostner"}, {"start": 65, "end": 70, "ent_type": "LOC", "text": "Italy"}]}
{"id": "test-02593", "text": "BOBSLEIGH-SHIMER PILOTS USA III TO SURPRISE WIN.", "gold_mentions": [{"start": 0, "end": 16, "ent_type": "MISC", "text": "BOBSLEIGH-SHIMER"}, {"start": 24, "end": 31, "ent_type": "ORG", "text": "USA III"}]}
{"id": "test-02594", "text": "IGLS, Austria 1996-12-07", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "LOC", "text": "IGLS"}, {"start": 6, "end": 13, "ent_type": "LOC", "text": "Austria"}]}
{"id": "test-02595", "text": "Brian Shimer piloted USA III to a surprise victory in a World Cup two-man bobsleigh race on Saturday.", "gold_mentions": [{"start": 0, "end": 12, "ent_type": "PER", "text": "Brian Shimer"}, {"start": 21, "end": 28, "ent_type": "ORG", "text": "USA III"}, {"start": 56, "end": 65, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-02596", "text": "Lying fifth after the first run, Shimer and breakman Randy Jones delivered a near-perfect second trip down the 1976 Olympic course for an aggregate time of one minute 45.91 seconds.", "gold_mentions": [{"start": 33, "end": 39, "ent_type": "PER", "text": "Shimer"}, {"start": 53, "end": 64, "ent_type": "PER", "text": "Randy Jones"}, {"start": 116, "end": 123, "ent_type": "MISC", "text": "Olympic"}]}
{"id": "test-02597", "text": "First run leaders Guenther Huber and breakman Antonio Tartaglia in the Italy I sleigh finished second two-hundredths of a second behind the Americans.", "gold_mentions": [{"start": 18, "end": 32, "ent_type": "PER", "text": "Guenther Huber"}, {"start": 46, "end": 63, "ent_type": "PER", "text": "Antonio Tartaglia"}, {"start": 71, "end": 76, "ent_type": "LOC", "text": "Italy"}, {"start": 140, "end": 149, "ent_type": "MISC", "text": "Americans"}]}
