{"id": "test-03398", "text": "MADRID 1996-12-07", "gold_mentions": [{"start": 0, "end": 6, "ent_type": "LOC", "text": "MADRID"}]}
{"id": "test-03399", "text": "Real Madrid's Balkan strike force of Davor Suker and Predrag Mijatovic shot their side to a 2-0 win over Barcelona in Spain's old firm game on Saturday.", "gold_mentions": [{"start": 0, "end": 11, "ent_type": "ORG", "text": "Real Madrid"}, {"start": 14, "end": 20, "ent_type": "LOC", "text": "Balkan"}, {"start": 37, "end": 48, "ent_type": "PER", "text": "Davor Suker"}, {"start": 53, "end": 70, "ent_type": "PER", "text": "Predrag Mijatovic"}, {"start": 105, "end": 114, "ent_type": "ORG", "text": "Barcelona"}, {"start": 118, "end": 123, "ent_type": "LOC", "text": "Spain"}]}
