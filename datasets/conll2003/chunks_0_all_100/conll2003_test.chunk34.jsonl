{"id": "test-03393", "text": "Summary of Saturday's Spanish first division match:", "gold_mentions": [{"start": 22, "end": 29, "ent_type": "MISC", "text": "Spanish"}]}
{"id": "test-03394", "text": "Real Madrid 2 (Davor Suker 24, Predrag Mijatovic 48) Barcelona 0.", "gold_mentions": [{"start": 0, "end": 11, "ent_type": "ORG", "text": "Real Madrid"}, {"start": 15, "end": 26, "ent_type": "PER", "text": "Davor Suker"}, {"start": 31, "end": 48, "ent_type": "PER", "text": "Predrag Mijatovic"}, {"start": 53, "end": 62, "ent_type": "ORG", "text": "Barcelona"}]}
