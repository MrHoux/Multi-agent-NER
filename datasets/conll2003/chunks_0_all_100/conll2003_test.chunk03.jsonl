{"id": "test-00222", "text": "Defenders - Dan Petrescu, Daniel Prodan, Anton Dobos, Cornel Papura, Liviu Ciobotariu, Tibor Selymess, Iulian Filipescu.", "gold_mentions": [{"start": 12, "end": 24, "ent_type": "PER", "text": "Dan Petrescu"}, {"start": 26, "end": 39, "ent_type": "PER", "text": "Daniel Prodan"}, {"start": 41, "end": 52, "ent_type": "PER", "text": "Anton Dobos"}, {"start": 54, "end": 67, "ent_type": "PER", "text": "Cornel Papura"}, {"start": 69, "end": 85, "ent_type": "PER", "text": "Liviu Ciobotariu"}, {"start": 87, "end": 101, "ent_type": "PER", "text": "Tibor Selymess"}, {"start": 103, "end": 119, "ent_type": "PER", "text": "Iulian Filipescu"}]}
{"id": "test-00223", "text": "Midfielders - Gheorghe Hagi, Gheorghe Popescu, Constantin Galca, Valentin Stefan, Basarab Panduru, Dorinel Munteanu, Ovidiu Stinga.", "gold_mentions": [{"start": 14, "end": 27, "ent_type": "PER", "text": "Gheorghe Hagi"}, {"start": 29, "end": 45, "ent_type": "PER", "text": "Gheorghe Popescu"}, {"start": 47, "end": 63, "ent_type": "PER", "text": "Constantin Galca"}, {"start": 65, "end": 80, "ent_type": "PER", "text": "Valentin Stefan"}, {"start": 82, "end": 97, "ent_type": "PER", "text": "Basarab Panduru"}, {"start": 99, "end": 115, "ent_type": "PER", "text": "Dorinel Munteanu"}, {"start": 117, "end": 130, "ent_type": "PER", "text": "Ovidiu Stinga"}]}
