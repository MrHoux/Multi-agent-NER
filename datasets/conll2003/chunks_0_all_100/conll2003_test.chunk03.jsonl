{"id": "test-00212", "text": "SOCCER - UNCAPPED PLAYERS CALLED TO FACE MACEDONIA.", "gold_mentions": [{"start": 41, "end": 50, "ent_type": "LOC", "text": "MACEDONIA"}]}
{"id": "test-00213", "text": "BUCHAREST 1996-12-06", "gold_mentions": [{"start": 0, "end": 9, "ent_type": "LOC", "text": "BUCHAREST"}]}
{"id": "test-00214", "text": "Romania trainer Anghel Iordanescu called up three uncapped players on Friday in his squad to face Macedonia next week in a World Cup qualifier.", "gold_mentions": [{"start": 0, "end": 7, "ent_type": "LOC", "text": "Romania"}, {"start": 16, "end": 33, "ent_type": "PER", "text": "Anghel Iordanescu"}, {"start": 98, "end": 107, "ent_type": "LOC", "text": "Macedonia"}, {"start": 123, "end": 132, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-00215", "text": "Midfielder Valentin Stefan and striker Viorel Ion of Otelul Galati and defender Liviu Ciobotariu of National Bucharest are the newcomers for the European group eight clash in Macedonia on December 14.", "gold_mentions": [{"start": 11, "end": 26, "ent_type": "PER", "text": "Valentin Stefan"}, {"start": 39, "end": 49, "ent_type": "PER", "text": "Viorel Ion"}, {"start": 53, "end": 66, "ent_type": "ORG", "text": "Otelul Galati"}, {"start": 80, "end": 96, "ent_type": "PER", "text": "Liviu Ciobotariu"}, {"start": 100, "end": 118, "ent_type": "ORG", "text": "National Bucharest"}, {"start": 145, "end": 153, "ent_type": "MISC", "text": "European"}, {"start": 175, "end": 184, "ent_type": "LOC", "text": "Macedonia"}]}
{"id": "test-00216", "text": "Iordanescu said he had picked them because of their good performances in the domestic championship in which National Bucharest are top and Otelul Galati third. \"", "gold_mentions": [{"start": 0, "end": 10, "ent_type": "PER", "text": "Iordanescu"}, {"start": 108, "end": 126, "ent_type": "ORG", "text": "National Bucharest"}, {"start": 139, "end": 152, "ent_type": "ORG", "text": "Otelul Galati"}]}
{"id": "test-00217", "text": "I think it's fair to give them a chance, \"he told reporters.", "gold_mentions": []}
{"id": "test-00218", "text": "League title-holders Steaua Bucharest, who finished bottom of their Champions' League group in the European Cup, have only two players in the squad.", "gold_mentions": [{"start": 21, "end": 37, "ent_type": "ORG", "text": "Steaua Bucharest"}, {"start": 68, "end": 85, "ent_type": "MISC", "text": "Champions' League"}, {"start": 99, "end": 111, "ent_type": "MISC", "text": "European Cup"}]}
{"id": "test-00219", "text": "Attacking midfielder Adrian Ilie, who recently moved from Steaua to Turkish club Galatasaray, is ruled out after two yellow-card offences.", "gold_mentions": [{"start": 21, "end": 32, "ent_type": "PER", "text": "Adrian Ilie"}, {"start": 58, "end": 64, "ent_type": "ORG", "text": "Steaua"}, {"start": 68, "end": 75, "ent_type": "MISC", "text": "Turkish"}, {"start": 81, "end": 92, "ent_type": "ORG", "text": "Galatasaray"}]}
{"id": "test-00220", "text": "Squad:", "gold_mentions": []}
