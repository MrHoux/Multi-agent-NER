{"id": "test-02428", "text": "The results were declared official.", "gold_mentions": []}
{"id": "test-02429", "text": "ALPINE SKIING-GLADISHIVA WINS WORLD CUP SUPER G.", "gold_mentions": [{"start": 7, "end": 24, "ent_type": "MISC", "text": "SKIING-GLADISHIVA"}, {"start": 30, "end": 39, "ent_type": "MISC", "text": "WORLD CUP"}]}
{"id": "test-02430", "text": "VAIL, Colorado 1996-12-07", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "LOC", "text": "VAIL"}, {"start": 6, "end": 14, "ent_type": "LOC", "text": "Colorado"}]}
{"id": "test-02431", "text": "Svetlana Gladishiva of Russia won the women's World Cup Super G race on Saturday.", "gold_mentions": [{"start": 0, "end": 19, "ent_type": "PER", "text": "Svetlana Gladishiva"}, {"start": 23, "end": 29, "ent_type": "LOC", "text": "Russia"}, {"start": 46, "end": 55, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-02432", "text": "Pernilla Wiberg of Sweden finished second and Carole Montillet of France came in third, according to provisional results.", "gold_mentions": [{"start": 0, "end": 15, "ent_type": "PER", "text": "Pernilla Wiberg"}, {"start": 19, "end": 25, "ent_type": "LOC", "text": "Sweden"}, {"start": 46, "end": 62, "ent_type": "PER", "text": "Carole Montillet"}, {"start": 66, "end": 72, "ent_type": "LOC", "text": "France"}]}
{"id": "test-02433", "text": "GOLF - THIRD ROUND OF JCPENNEY CLASSIC WASHED OUT.", "gold_mentions": [{"start": 22, "end": 38, "ent_type": "MISC", "text": "JCPENNEY CLASSIC"}]}
{"id": "test-02434", "text": "TARPON SPRINGS, Florida 1996-12-07", "gold_mentions": [{"start": 0, "end": 14, "ent_type": "LOC", "text": "TARPON SPRINGS"}, {"start": 16, "end": 23, "ent_type": "LOC", "text": "Florida"}]}
{"id": "test-02435", "text": "Heavy rains on Saturday washed out the third round of the $1.5 million JCPenney Classic at the Innisbrook Hilton Resort.", "gold_mentions": [{"start": 71, "end": 87, "ent_type": "MISC", "text": "JCPenney Classic"}, {"start": 95, "end": 119, "ent_type": "LOC", "text": "Innisbrook Hilton Resort"}]}
{"id": "test-02436", "text": "Officials said the tournament would be reduced to 54 holes for the first time in its 37-year history.", "gold_mentions": []}
{"id": "test-02437", "text": "The final round of the special event, which pairs players from the PGA and LPGA Tours, will be played in the alternate shot format on Sunday.", "gold_mentions": [{"start": 67, "end": 70, "ent_type": "ORG", "text": "PGA"}, {"start": 75, "end": 79, "ent_type": "ORG", "text": "LPGA"}]}
{"id": "test-02438", "text": "The duo of Pat Hurst and Scott McCarron were tied for the lead with the team of Donna Andrews and Mike Hulbert at 13-under-par 129 through 36 holes.", "gold_mentions": [{"start": 11, "end": 20, "ent_type": "PER", "text": "Pat Hurst"}, {"start": 25, "end": 39, "ent_type": "PER", "text": "Scott McCarron"}, {"start": 80, "end": 93, "ent_type": "PER", "text": "Donna Andrews"}, {"start": 98, "end": 110, "ent_type": "PER", "text": "Mike Hulbert"}]}
{"id": "test-02439", "text": "The tandem of reigning U.S. Amateur champions Kelli Kuehne and Tiger Woods were another shot back at 12-under 130.", "gold_mentions": [{"start": 23, "end": 27, "ent_type": "LOC", "text": "U.S."}, {"start": 46, "end": 58, "ent_type": "PER", "text": "Kelli Kuehne"}, {"start": 63, "end": 74, "ent_type": "PER", "text": "Tiger Woods"}]}
{"id": "test-02440", "text": "Defending champions Beth Daniel and Davis Love will start the final round six shots off the pace.", "gold_mentions": [{"start": 20, "end": 31, "ent_type": "PER", "text": "Beth Daniel"}, {"start": 36, "end": 46, "ent_type": "PER", "text": "Davis Love"}]}
{"id": "test-02441", "text": "ALPINE SKIING-WOMEN'S DOWNHILL WINNER PROFILE.", "gold_mentions": []}
{"id": "test-02442", "text": "VAIL, Colorado 1996-12-07", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "LOC", "text": "VAIL"}, {"start": 6, "end": 14, "ent_type": "LOC", "text": "Colorado"}]}
{"id": "test-02443", "text": "Profile of the winner of Saturday's women's World Cup downhill race:", "gold_mentions": [{"start": 44, "end": 53, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-02444", "text": "Name: Renate Goetschl", "gold_mentions": [{"start": 6, "end": 21, "ent_type": "PER", "text": "Renate Goetschl"}]}
{"id": "test-02445", "text": "Age: 20", "gold_mentions": []}
{"id": "test-02446", "text": "Nation: Austria", "gold_mentions": [{"start": 8, "end": 15, "ent_type": "LOC", "text": "Austria"}]}
{"id": "test-02447", "text": "Previous victories (two): slalom, Lillehammer Norway, 1993; super G, Flachau, Austria, 1995.", "gold_mentions": [{"start": 34, "end": 45, "ent_type": "LOC", "text": "Lillehammer"}, {"start": 46, "end": 52, "ent_type": "LOC", "text": "Norway"}, {"start": 69, "end": 76, "ent_type": "LOC", "text": "Flachau"}, {"start": 78, "end": 85, "ent_type": "LOC", "text": "Austria"}]}
{"id": "test-02448", "text": "Other facts: As a qualifier for the 1993 World Cup finals through Europa Cup results, 16-year-old Goetschl won the slalom to become history's youngest World Cup victor.", "gold_mentions": [{"start": 36, "end": 50, "ent_type": "MISC", "text": "1993 World Cup"}, {"start": 66, "end": 76, "ent_type": "MISC", "text": "Europa Cup"}, {"start": 98, "end": 106, "ent_type": "PER", "text": "Goetschl"}, {"start": 151, "end": 160, "ent_type": "MISC", "text": "World Cup"}]}
{"id": "test-02449", "text": "ALPINE SKIING-WOMEN'S WORLD CUP STANDINGS.", "gold_mentions": [{"start": 22, "end": 31, "ent_type": "MISC", "text": "WORLD CUP"}]}
