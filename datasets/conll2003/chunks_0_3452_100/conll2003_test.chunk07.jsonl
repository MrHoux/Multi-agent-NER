{"id": "test-00687", "text": "Quarter-final results at the $6 million Grand Slam Cup tennis tournament on Friday: Goran Ivanisevic (Croatia) beat Mark Woodforde (Australia) 6-4 6-4", "gold_mentions": [{"start": 40, "end": 54, "ent_type": "MISC", "text": "Grand Slam Cup"}, {"start": 84, "end": 100, "ent_type": "PER", "text": "Goran Ivanisevic"}, {"start": 102, "end": 109, "ent_type": "LOC", "text": "Croatia"}, {"start": 116, "end": 130, "ent_type": "PER", "text": "Mark Woodforde"}, {"start": 132, "end": 141, "ent_type": "LOC", "text": "Australia"}]}
{"id": "test-00688", "text": "Yevgeny Kafelnikov (Russia) beat Jim Courier (U.S.) 2-6 6-4 8-6", "gold_mentions": [{"start": 0, "end": 18, "ent_type": "PER", "text": "Yevgeny Kafelnikov"}, {"start": 20, "end": 26, "ent_type": "LOC", "text": "Russia"}, {"start": 33, "end": 44, "ent_type": "PER", "text": "Jim Courier"}, {"start": 46, "end": 50, "ent_type": "LOC", "text": "U.S."}]}
{"id": "test-00689", "text": "SOCCER - WEAH HEAD-BUTT DEPRIVES PORTUGAL OF COSTA.", "gold_mentions": [{"start": 9, "end": 13, "ent_type": "PER", "text": "WEAH"}, {"start": 33, "end": 41, "ent_type": "LOC", "text": "PORTUGAL"}, {"start": 45, "end": 50, "ent_type": "PER", "text": "COSTA"}]}
{"id": "test-00690", "text": "LISBON 1996-12-06", "gold_mentions": [{"start": 0, "end": 6, "ent_type": "LOC", "text": "LISBON"}]}
{"id": "test-00691", "text": "Portugal called up Porto central defender Joao Manuel Pinto on Friday to face Germany in a World Cup qualifier in place of injured club colleague Jorge Costa, who is still nursing a broken nose after being head-butted by Liberian striker Georg Weah.", "gold_mentions": [{"start": 0, "end": 8, "ent_type": "LOC", "text": "Portugal"}, {"start": 19, "end": 24, "ent_type": "ORG", "text": "Porto"}, {"start": 42, "end": 59, "ent_type": "PER", "text": "Joao Manuel Pinto"}, {"start": 78, "end": 85, "ent_type": "LOC", "text": "Germany"}, {"start": 91, "end": 100, "ent_type": "MISC", "text": "World Cup"}, {"start": 146, "end": 157, "ent_type": "PER", "text": "Jorge Costa"}, {"start": 221, "end": 229, "ent_type": "MISC", "text": "Liberian"}, {"start": 238, "end": 248, "ent_type": "PER", "text": "Georg Weah"}]}
{"id": "test-00692", "text": "Costa has not played since being struck by the AC Milan forward after a bad-tempered European Champions' League game on November 27.", "gold_mentions": [{"start": 0, "end": 5, "ent_type": "PER", "text": "Costa"}, {"start": 47, "end": 55, "ent_type": "ORG", "text": "AC Milan"}, {"start": 85, "end": 111, "ent_type": "MISC", "text": "European Champions' League"}]}
{"id": "test-00693", "text": "Portugal lead European qualifying group nine with seven points from four games, one more than Ukraine and three more than Germany, who have only played twice.", "gold_mentions": [{"start": 0, "end": 8, "ent_type": "LOC", "text": "Portugal"}, {"start": 14, "end": 22, "ent_type": "MISC", "text": "European"}, {"start": 94, "end": 101, "ent_type": "LOC", "text": "Ukraine"}, {"start": 122, "end": 129, "ent_type": "LOC", "text": "Germany"}]}
{"id": "test-00694", "text": "The Portuguese host Germany on December 14.", "gold_mentions": [{"start": 4, "end": 14, "ent_type": "MISC", "text": "Portuguese"}, {"start": 20, "end": 27, "ent_type": "LOC", "text": "Germany"}]}
