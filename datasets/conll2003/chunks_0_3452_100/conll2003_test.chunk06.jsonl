{"id": "test-00557", "text": "NCAA AMERICAN FOOTBALL-OHIO STATE'S PACE FIRST REPEAT LOMBARDI AWARD WINNER.", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "ORG", "text": "NCAA"}, {"start": 14, "end": 33, "ent_type": "MISC", "text": "FOOTBALL-OHIO STATE"}, {"start": 36, "end": 40, "ent_type": "PER", "text": "PACE"}, {"start": 54, "end": 68, "ent_type": "MISC", "text": "LOMBARDI AWARD"}]}
{"id": "test-00558", "text": "HOUSTON 1996-12-05", "gold_mentions": [{"start": 0, "end": 7, "ent_type": "LOC", "text": "HOUSTON"}]}
{"id": "test-00559", "text": "Ohio State left tackle Orlando Pace became the first repeat winner of the Lombardi Award Thursday night when the Rotary Club of Houston again honoured him as college football's lineman of the year.", "gold_mentions": [{"start": 0, "end": 10, "ent_type": "ORG", "text": "Ohio State"}, {"start": 23, "end": 35, "ent_type": "PER", "text": "Orlando Pace"}, {"start": 74, "end": 88, "ent_type": "MISC", "text": "Lombardi Award"}, {"start": 113, "end": 124, "ent_type": "ORG", "text": "Rotary Club"}, {"start": 128, "end": 135, "ent_type": "LOC", "text": "Houston"}]}
{"id": "test-00560", "text": "Pace, a junior, helped Ohio State to a 10-1 record and a berth in the Rose Bowl against Arizona State.", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "PER", "text": "Pace"}, {"start": 23, "end": 33, "ent_type": "ORG", "text": "Ohio State"}, {"start": 70, "end": 79, "ent_type": "MISC", "text": "Rose Bowl"}, {"start": 88, "end": 101, "ent_type": "ORG", "text": "Arizona State"}]}
{"id": "test-00561", "text": "He was the most dominant offensive lineman in the country and also played defensive line in goal-line situations.", "gold_mentions": []}
{"id": "test-00562", "text": "Last year, Pace became the first sophomore to win the award since its inception in 1970.", "gold_mentions": [{"start": 11, "end": 15, "ent_type": "PER", "text": "Pace"}]}
{"id": "test-00563", "text": "Pace outdistanced three senior finalists -- Virginia Tech defensive end Cornell Brown, Arizona State offensive tackle Juan Roque and defensive end Jared Tomich of Nebraska.", "gold_mentions": [{"start": 0, "end": 4, "ent_type": "PER", "text": "Pace"}, {"start": 44, "end": 57, "ent_type": "ORG", "text": "Virginia Tech"}, {"start": 72, "end": 85, "ent_type": "PER", "text": "Cornell Brown"}, {"start": 87, "end": 100, "ent_type": "ORG", "text": "Arizona State"}, {"start": 118, "end": 128, "ent_type": "PER", "text": "Juan Roque"}, {"start": 147, "end": 159, "ent_type": "PER", "text": "Jared Tomich"}, {"start": 163, "end": 171, "ent_type": "ORG", "text": "Nebraska"}]}
{"id": "test-00564", "text": "The Lombardi Award is presented to the college lineman who, in addition to outstanding effort on the field, best exemplifies the characteristics and discipline of Vince Lombardi, legendary coach of the Green Bay Packers.", "gold_mentions": [{"start": 4, "end": 18, "ent_type": "MISC", "text": "Lombardi Award"}, {"start": 163, "end": 177, "ent_type": "PER", "text": "Vince Lombardi"}, {"start": 202, "end": 219, "ent_type": "ORG", "text": "Green Bay Packers"}]}
